# ===== Server Config =====
PORT=3000
NODE_ENV=production

# ===== Database =====
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://rpguser:YOUR_PASSWORD_HERE@cluster.mongodb.net/?retryWrites=true&w=majority

# ===== CORS =====
# Your Netlify frontend URL (needed for cross-origin requests)
# Example: https://tranquil-melba-77872b.netlify.app
CLIENT_ORIGIN=https://YOUR_NETLIFY_DOMAIN.netlify.app

# ===== Optional =====
# LOG_LEVEL=debug

